# AI4ML environment configuration – copy this file to .env and fill in your values.
# .env is loaded automatically by the backend at startup (pydantic-settings).
#
# ── Huawei MaaS API key (required for Windows / cloud setup) ──────────────────
AI4ML_MLZERO_OPENAI_API_KEY=your-huawei-maas-api-key-here

# ── Optional overrides (defaults shown; uncomment to change) ──────────────────
# AI4ML_MLZERO_OPENAI_BASE_URL=https://api.modelarts-maas.com/openai/v1
# AI4ML_MLZERO_CONFIG_PATH=backend/config/mlzero-huawei-openai.yaml
# AI4ML_MLZERO_MAX_ITERATIONS=2

# ── Local llama-cpp switch (Mac / dev only) ───────────────────────────────────
# Set to true to use a local llama-cpp-python server instead of Huawei MaaS.
# AI4ML_MLZERO_USE_LOCAL_PROVIDER=false
# AI4ML_MLZERO_CONFIG_PATH=backend/config/mlzero-local-openai.yaml
# AI4ML_MLZERO_RUNNER_EXECUTABLE=mamba
